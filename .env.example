# GridWatch — required environment variables
# Copy this file to .env and fill in the values Greg provided.
# Never commit .env to git.
# Note: .env values override any stale keys already exported in your shell.

# Anthropic API — primary LLM backend
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — alternative LLM backend (set USE_OPENROUTER=true to activate)
OPENROUTER_API_KEY=sk-or-v1-...
USE_OPENROUTER=false

# Model override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# EIA — grid demand + generation mix data
EIA_API_KEY=...

# /briefing endpoint auth token — any strong random string, required
BRIEFING_TOKEN=pick-a-strong-random-string

# ntfy.sh — on-call alert push notifications
# Comma-separated list of topics — all receive the alert simultaneously.
# Each analyst subscribes to their own topic in the ntfy app.
NTFY_TOPIC=gridwatch-ismael,gridwatch-michael,gridwatch-christian,gridwatch-edwin,gridwatch-juan

# ntfy.sh — demand response dispatch channel
# Must be set. Keep separate from NTFY_TOPIC.
DR_TOPIC=your-private-dr-topic

# Stub mode — run with fake data, no API keys needed
USE_STUBS=false
