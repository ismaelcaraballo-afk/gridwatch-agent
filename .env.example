# Copy to .env and fill in values (never commit .env).
#
# agent.py and server.py load this file with override=True, so these values
# replace any stale ANTHROPIC_API_KEY (etc.) already exported in your shell.

# Required for agent.py unless USE_OPENROUTER=true below.
ANTHROPIC_API_KEY=

# Optional: model id (defaults in agent.py / server.py).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Anthropic API alternative — set OPENROUTER_API_KEY and USE_OPENROUTER=true to route via OpenRouter.
OPENROUTER_API_KEY=
USE_OPENROUTER=false

# EIA Open Data — required for live grid demand / generation (unless USE_STUBS=true).
EIA_API_KEY=

# true = stub tools (no EIA/NOAA/RSS calls); good for testing the agent loop only.
USE_STUBS=false

# ntfy.sh topic for send_alert (optional; see tools/alert.py).
NTFY_TOPIC=

# Demand-response tool topic override (optional; see tools/demand_response.py).
DR_TOPIC=
